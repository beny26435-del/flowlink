{
  "name": "arclet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "test:contracts": "forge test -vvv",
    "deploy:arclet": "npm run deploy:arc:v4",
    "deploy:arc": "set -a; [ ! -f .env ] || . ./.env; set +a; forge script script/DeployFlowLink.s.sol:DeployFlowLink --rpc-url $ARC_TESTNET_RPC_URL --broadcast",
    "deploy:arc:v2": "set -a; [ ! -f .env ] || . ./.env; set +a; forge script script/DeployFlowLinkV2.s.sol:DeployFlowLinkV2 --rpc-url $ARC_TESTNET_RPC_URL --broadcast",
    "deploy:arc:v3": "set -a; [ ! -f .env ] || . ./.env; set +a; forge script script/DeployFlowLinkV3.s.sol:DeployFlowLinkV3 --rpc-url $ARC_TESTNET_RPC_URL --broadcast",
    "deploy:arc:v4": "set -a; [ ! -f .env ] || . ./.env; set +a; forge script script/DeployFlowLinkV4.s.sol:DeployFlowLinkV4 --rpc-url $ARC_TESTNET_RPC_URL --broadcast",
    "smoke:arclet": "npm run smoke:arc:v4",
    "smoke:arc": "tsx scripts/smoke.ts",
    "smoke:arc:v2": "tsx scripts/smoke-v2.ts",
    "smoke:arc:v3": "tsx scripts/smoke-v3.ts",
    "smoke:arc:v4": "tsx scripts/smoke-v4.ts"
  },
  "dependencies": {
    "@circle-fin/adapter-viem-v2": "^1.11.2",
    "@circle-fin/app-kit": "^1.7.0",
    "@tanstack/react-query": "^5.101.0",
    "dotenv": "^16.4.7",
    "framer-motion": "^12.40.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.8.3",
    "viem": "^2.31.0",
    "wagmi": "^3.6.16"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.19.4"
  }
}
